# ============================================================================
# Phase 64 — systemd environment file for agent-app daemon
# ============================================================================
# Install:
#   sudo cp agent-app-daemon.env /etc/agent-app/agent-app-daemon.env
#   sudo chmod 600 /etc/agent-app/agent-app-daemon.env
# ============================================================================

# ---- Paths ----
AGENT_APP_CONFIG=/etc/agent-app/daemon.yaml
AGENT_APP_CONTROL_DB=/var/lib/agent-app/control_plane.db

# ---- Control plane auth (REPLACE with real token!) ----
# AGENT_APP_CONTROL_TOKEN=replace-me-with-real-token

# ---- Optional overrides ----
# AGENT_APP_HEALTH_PORT=8080
# AGENT_APP_CONTROL_PORT=8090
